<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>รายละเอียดหนังสือ</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="container">
        <div class="header-section">
            <h1>📖 รายละเอียดหนังสือ</h1>
        </div>
        
        <div class="detail-box">
            <div class="detail-item"><span class="detail-label">ID หนังสือ:</span> <%= book.id %></div>
            <div class="detail-item"><span class="detail-label">ชื่อหนังสือ (Title):</span> <%= book.title %></div>
            <div class="detail-item"><span class="detail-label">ราคา (Price):</span> ฿<%= book.price %></div>
            <div class="detail-item"><span class="detail-label">ผู้แต่ง (Author):</span> <%= book.author ? book.author.name : '-' %></div>
            <div class="detail-item"><span class="detail-label">หมวดหมู่ (Category):</span> <%= book.category ? book.category.name : '-' %></div>
        </div>

        <div>
            <a href="/edit/<%= book.id %>" class="btn btn-primary">✏️ แก้ไขข้อมูล</a>
            <a href="/" class="btn btn-secondary" style="margin-left: 10px;">⬅ กลับหน้าแรก</a>
        </div>
    </div>

</body>
</html>