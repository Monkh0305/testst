<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>เพิ่มหนังสือใหม่</title>
</head>
<body>
    <h2>➕ เพิ่มหนังสือใหม่</h2>

    <form method="POST" action="/create">
        <label>ชื่อหนังสือ (Title):</label><br>
        <input type="text" name="title" required><br><br>

        <label>ราคา (Price):</label><br>
        <input type="number" step="0.01" name="price" required><br><br>

        <label>ผู้แต่ง (Author):</label><br>
        <input type="text" name="authorName" required><br><br>

        <label>หมวดหมู่ (Category):</label><br>
        <select name="genreId" required>
            <option value="">-- เลือกหมวดหมู่ --</option>
            <% categories.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.name %></option>
            <% }) %>
        </select><br><br>

        <button type="submit">💾 บันทึกข้อมูล</button>
    </form>
    
    <br>
    <a href="/">⬅ ยกเลิกและกลับหน้าแรก</a>
</body>
</html>