<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>รายการหนังสือ</title>
</head>
<body>
    <h1>📚 รายการหนังสือทั้งหมด</h1>
    <a href="/create">➕ เพิ่มหนังสือใหม่</a> | 
    <a href="/report">📊 ดูรายงาน</a>
    <br><br>

    <table border="1" cellpadding="8" cellspacing="0">
        <thead>
            <tr>
                <th>ID</th>
                <th>ชื่อหนังสือ (Title)</th>
                <th>ราคา (Price)</th>
                <th>ผู้แต่ง (Author)</th>
                <th>หมวดหมู่ (Category)</th>
                <th>จัดการ</th>
            </tr>
        </thead>
        <tbody>
            <% books.forEach(b => { %>
                <tr>
                    <td><%= b.id %></td>
                    <td><%= b.title %></td>
                    <td>฿<%= b.price %></td>
                    <td><%= b.author ? b.author.name : '-' %></td>
                    <td><%= b.category ? b.category.name : '-' %></td>
                    <td>
                        <a href="/view/<%= b.id %>">👁️ ดูรายละเอียด</a> | 
                        <a href="/edit/<%= b.id %>">✏️ แก้ไข</a> | 
                        <a href="/delete/<%= b.id %>" onclick="return confirm('แน่ใจหรือไม่ที่จะลบหนังสือเล่มนี้?');">❌ ลบ</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>