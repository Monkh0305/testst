<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>แก้ไขหนังสือ</title>
</head>
<body>
    <h2>✏️ แก้ไขข้อมูลหนังสือ (ID: <%= book.id %>)</h2>

    <form method="POST" action="/edit/<%= book.id %>">
        <label>ชื่อหนังสือ (Title):</label><br>
        <input type="text" name="title" value="<%= book.title %>" required><br><br>

        <label>ราคา (Price):</label><br>
        <input type="number" step="0.01" name="price" value="<%= book.price %>" required><br><br>

        <label>ผู้แต่ง (Author):</label><br>
        <input type="text" name="authorName" value="<%= book.author ? book.author.name : '' %>" required><br><br>

        <label>หมวดหมู่ (Category):</label><br>
        <select name="genreId" required>
            <option value="">-- เลือกหมวดหมู่ --</option>
            <% categories.forEach(c => { %>
                <option value="<%= c.id %>" <%= c.id === book.genreId ? 'selected' : '' %> >
                    <%= c.name %>
                </option>
            <% }) %>
        </select><br><br>

        <button type="submit">💾 บันทึกการแก้ไข</button>
    </form>
    
    <br>
    <a href="/">⬅ ยกเลิกและกลับหน้าแรก</a>
</body>
</html>