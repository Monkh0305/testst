<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>รายงานหนังสือ</title>
</head>
<body>
    <h2>📊 หน้ารายงานหนังสือ (Report)</h2>

    <form method="GET" action="/report">
        <label>ค้นหาตามหมวดหมู่:</label>
        <select name="genreId">
            <option value="">-- แสดงทั้งหมด (All) --</option>
            <% categories.forEach(c => { %>
                <option value="<%= c.id %>" <%= c.id == selectedGenre ? 'selected' : '' %>>
                    <%= c.name %>
                </option>
            <% }) %>
        </select>
        <button type="submit">🔍 กรองข้อมูล</button>
    </form>

    <br>

    <table border="1" cellpadding="8" cellspacing="0">
        <thead>
            <tr style="background-color: #eee;">
                <th>ชื่อหนังสือ (Title)</th>
                <th>ราคา (Price)</th>
                <th>ผู้แต่ง (Author)</th>
                <th>หมวดหมู่ (Category)</th>
            </tr>
        </thead>
        <tbody>
            <% if (books.length > 0) { %>
                <% books.forEach(b => { %>
                    <tr>
                        <td><%= b.title %></td>
                        <td>฿<%= b.price %></td>
                        <td><%= b.author ? b.author.name : '-' %></td>
                        <td><%= b.category ? b.category.name : '-' %></td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="4" style="text-align: center;">ไม่พบข้อมูลหนังสือในหมวดหมู่นี้</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <br>
    <a href="/">⬅ กลับหน้าแรก</a>
</body>
</html>